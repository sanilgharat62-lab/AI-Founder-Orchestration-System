# Groq (optional — app works with built-in templates without this)
# Get a free key at https://console.groq.com/keys (starts with gsk_)
GROQ_API_KEY=gsk_your-real-key-here
GITHUB_TOKEN=ghp_your-token-here
NOTION_API_KEY=secret_your-key-here
NOTION_DATABASE_ID=your-database-id
# TAVILY_API_KEY powers Evidence Citations (Startup Advisor + Market Research)
# and is reused by Judge Mode's context. Without it, those agents fall back to
# uncited output and Judge Mode still runs off agent text alone.
TAVILY_API_KEY=tvly-your-real-key-here
FIRECRAWL_API_KEY=fc-your-real-key-here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook
